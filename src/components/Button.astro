---
interface Props {
  href: string;
  text: string;
  variant?: "main" | "white" | "secondary" | "warning";
}

const { href, text, variant = "main" } = Astro.props;

const styles = {
  main:      { bg: "#ff3232", text: "#fafafa", hover: "#ff5b3d" },
  white:     { bg: "#fafafa", text: "#ff3232", hover: "#78af2d" },
  secondary: { bg: "#78af2d", text: "#fafafa", hover: "#85be3a" },
  warning:   { bg: "#ff3232", text: "#fafafa", hover: "#ff5b3d" }
};

const s = styles[variant];
---


  href={href}
  class="btn"
  style={`--bg: ${s.bg}; --text: ${s.text}; --hover: ${s.hover};`}
  onmouseover="this.style.backgroundColor='var(--hover)'"
  onmouseout="this.style.backgroundColor='var(--bg)'"
>
  {text}
</a>

<style>
  .btn {
    display: inline-block;
    padding: 0.75em 1.5em;
    background-color: var(--bg);
    color: var(--text);
    text-decoration: none;
    border-radius: 50px;
    font-weight: bold;
    text-transform: uppercase;
    transition: all 0.3s ease;
  }

  @media (max-width: 768px) {
    .btn {
      padding: 1em;
    }
  }
</style>