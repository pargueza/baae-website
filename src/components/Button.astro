---
interface Props {
  href: string;
  text: string;
  variant?: "main" | "white" | "secondary" | "warning";
}

const {
  href,
  text,
  variant = "main"
} = Astro.props;

const styles = {
  main:      { bg: "#ff3232", text: "#fafafa", hover: "#ff5b3d" },
  white:     { bg: "#fafafa", text: "#ff3232", hover: "#78af2d" },
  secondary: { bg: "#78af2d", text: "#fafafa", hover: "#85be3a" },
  warning:   { bg: "#ff3232", text: "#fafafa", hover: "#ff5b3d" }
};

const s = styles[variant];
---

<a 
  href={href}
  class="btn"
  style={`
    display: inline-block;
    padding: 0.75em 1.5em;
    background-color: ${s.bg};
    color: ${s.text};
    text-decoration: none;
    border-radius: 50px;
    font-weight: bold;
    text-transform: uppercase;
    transition: all 0.3s ease;
  `}
  onmouseover={`this.style.backgroundColor='${s.hover}'`}
  onmouseout={`this.style.backgroundColor='${s.bg}'`}
>
  {text}
</a>

<style>
  @media (max-width: 768px) {
    .btn {
      padding: 1em;
    }
  }
</style>