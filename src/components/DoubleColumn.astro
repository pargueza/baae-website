---
interface Props {
  heading?: string;
  text: string;
  imageUrl: string;
  imageAlt: string;
  imagePosition?: "left" | "right";
  buttonText?: string;
  buttonLink?: string;
}

const {
  heading,
  text,
  imageUrl,
  imageAlt,
  imagePosition = "right",
  buttonText,
  buttonLink
} = Astro.props;

const imageColumn = imagePosition === "left" ? "order-first" : "order-last";
const textColumn = imagePosition === "left" ? "order-last" : "order-first";
---

<section class="w-full py-16 px-4">
  <div class="max-w-6xl mx-auto flex flex-col lg:flex-row gap-8 items-center">
    <div class={`w-full lg:w-1/2 ${imageColumn}`}>
      <img 
        src={imageUrl} 
        alt={imageAlt}
        class="w-full h-auto rounded-lg"
      />
    </div>
    
    <div class={`w-full lg:w-1/2 ${textColumn}`}>
      {heading && <h2 class="text-4xl font-bold mb-4">{heading}</h2>}
      <p class="text-lg mb-6 text-gray-700">{text}</p>
      {buttonText && (
        <a 
          href={buttonLink}
          class="inline-block bg-accent-green text-white px-6 py-3 rounded-full hover:bg-yellow-green transition-colors"
        >
          {buttonText}
        </a>
      )}
    </div>
  </div>
</section>
