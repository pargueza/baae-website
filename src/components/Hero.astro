---
import Button from './Button.astro';

interface Props {
  title: string;
  subtitle?: string;
  buttonText?: string;
  buttonLink?: string;
  bgColor?: string;
  bgImage?: string;
  textColor?: string;
  buttonVariant?: "main" | "white" | "secondary" | "warning";
}

const {
  title,
  subtitle,
  buttonText = "Learn More",
  buttonLink = "/",
  bgColor = "var(--accent-green)",
  bgImage,
  textColor = "var(--white)",
  buttonVariant = "main"
} = Astro.props;
---

<section 
  style={`
    width: 100%;
    padding: 5em 1em;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    background-color: ${bgColor};
    color: ${textColor};
    ${bgImage ? `background-image: url(${bgImage}); background-size: cover; background-position: center;` : ""}
  `}
>
  <div style={bgImage ? "background-color: rgba(0,0,0,0.4); padding: 5em 1em; width: 100%;" : ""}>
    <h1 style={`font-size: 3.5em; margin-bottom: 0.5em; color: ${textColor};`}>{title}</h1>
    {subtitle && <h2 style={`font-size: 1.75em; margin-bottom: 1.5em; color: ${textColor};`}>{subtitle}</h2>}
    {buttonText && (
      <Button 
        href={buttonLink}
        text={buttonText}
        variant={buttonVariant}
      />
    )}
  </div>
</section>