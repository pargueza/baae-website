---
import Button from './Button.astro';

interface Props {
  title: string;
  subtitle?: string;
  buttonText?: string;
  buttonLink?: string;
  bgColor?: "green" | "red" | "white";
  bgImage?: string;
  textColor?: string;
  buttonVariant?: "main" | "white" | "secondary" | "warning";
}

const {
  title,
  subtitle,
  buttonText = "Learn More",
  buttonLink = "/",
  bgColor = "green",
  bgImage,
  textColor = "white",
  buttonVariant = "main"
} = Astro.props;

const colorMap = {
  green: "var(--accent-green)",
  red: "var(--accent)",
  white: "var(--white)"
};

const textColorMap = {
  white: "var(--white)",
  dark: "var(--text)"
};

const bgColorValue = colorMap[bgColor] || "var(--accent-green)";
const textColorValue = textColor === "white" ? textColorMap.white : textColorMap.dark;
---

<section 
  class="full-width"
  style={`
    padding: 5em 1.5em;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    background-color: ${bgColorValue};
    color: ${textColorValue};
    ${bgImage ? `background-image: url(${bgImage}); background-size: cover; background-position: center;` : ""}
  `}
>
  <div style={bgImage ? "background-color: rgba(0,0,0,0.4); padding: 5em 1em; width: 100%; box-sizing: border-box;" : ""}>
    <h1 class="hero-title" style={`margin-bottom: 0.5em; color: ${textColorValue};`}>{title}</h1>
    {subtitle && <h2 style={`font-size: 1.75em; margin-bottom: 1.5em; color: ${textColorValue};`}>{subtitle}</h2>}
    
    <slot />
    
    {buttonText && (
      <Button 
        href={buttonLink}
        text={buttonText}
        variant={buttonVariant}
      />
    )}
  </div>
</section>

<style>
  .hero-title {
    font-size: 3.5em;
  }

  @media (max-width: 720px) {
    section {
      padding: 3em 1.5em;
      overflow: hidden;
    }

    .hero-title {
      font-size: 2em;
      word-break: break-word;
      hyphens: auto;
    }
  }
</style>