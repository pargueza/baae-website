<section 
  style={`
    width: 100%;
    margin: 0;
    padding: 5em 1em;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    background-color: ${bgColorValue};
    color: ${textColorValue};
    ${bgImage ? `background-image: url(${bgImage}); background-size: cover; background-position: center;` : ""}
  `}
>
  <div style={bgImage ? "background-color: rgba(0,0,0,0.4); padding: 5em 1em; width: 100%;" : ""}>
    <h1 class="hero-title" style={`margin-bottom: 0.5em; color: ${textColorValue};`}>{title}</h1>
    {subtitle && <h2 style={`font-size: 1.75em; margin-bottom: 1.5em; color: ${textColorValue};`}>{subtitle}</h2>}
    
    <slot />
    
    {buttonText && (
      <Button 
        href={buttonLink}
        text={buttonText}
        variant={buttonVariant}
      />
    )}
  </div>
</section>

<style>
  .hero-title {
    font-size: 3.5em;
  }

  @media (max-width: 720px) {
    section {
      width: 100vw;
      margin-left: 0;
      padding: 3em 1em;
    }

    .hero-title {
      font-size: 2em;
    }
  }
</style>