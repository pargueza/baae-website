---
interface Column {
  heading: string;
  content: string;
  icon?: string;
}

interface Props {
  columns: Column[];
  bgColor?: string;
  textColor?: string;
}

const {
  columns,
  bgColor = "bg-white",
  textColor = "text-gray-900"
} = Astro.props;
---

<section class={`w-full py-16 px-4 ${bgColor} ${textColor}`}>
  <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-8">
    {columns.map((column) => (
      <div class="flex flex-col items-center text-center">
        {column.icon && (
          <div class="text-4xl mb-4">{column.icon}</div>
        )}
        <h3 class="text-2xl font-bold mb-4">{column.heading}</h3>
        <p class="text-base leading-relaxed">{column.content}</p>
      </div>
    ))}
  </div>
</section>
