---
interface Props {
  heading: string;
  description?: string;
  buttonText?: string;
  buttonLink?: string;
  bgColor?: string;
  bgImage?: string;
  textColor?: string;
}

const {
  heading,
  description,
  buttonText = "Learn More",
  buttonLink = "/",
  bgColor = "bg-accent",
  bgImage,
  textColor = "text-white"
} = Astro.props;
---

<section 
  class={`w-full py-20 px-4 flex flex-col justify-center items-center text-center ${bgColor} ${textColor}`}
  style={bgImage ? `background-image: url(${bgImage}); background-size: cover; background-position: center;` : ""}
>
  <div class={bgImage ? "bg-black/40 w-full py-20 px-4 flex flex-col justify-center items-center" : ""}>
    <h2 class="text-4xl font-bold mb-4">{heading}</h2>
    {description && <p class="text-lg mb-8 max-w-2xl">{description}</p>}
    <a 
      href={buttonLink}
      class="bg-white text-accent px-8 py-3 rounded-full hover:bg-accent hover:text-white transition-colors font-bold uppercase"
    >
      {buttonText}
    </a>
  </div>
</section>
