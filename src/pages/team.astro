---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<Hero
					title="Meet Your BAAE BFFs"
					subtitle="Nurturing Friendships and Lifelong Connections"
					buttonText="Get Started"
					buttonLink="/contact"
					bgColor="red"
					buttonVariant="white"
					/>

			<div style="display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: left;">
				<h2 style="color: var(--accent-green);">Meet Nadine</h2>
				<p>
					Nadine is the founder of Bay Area Angels & Entrepreneurs (BAAE). She’s a seasoned marketing, PR, and communications professional with over 10 years of experience helping ideas grow through storytelling, digital marketing, and community-centered events. Nadine is passionate about bringing people together and creating spaces that feel thoughtful, welcoming, and genuinely supportive.
				</p>
				<p>
					Nadine is the founder of Bay Area Angels & Entrepreneurs (BAAE). She’s a seasoned marketing, PR, and communications professional with over 10 years of experience helping ideas grow through storytelling, digital marketing, and community-centered events. Nadine is passionate about bringing people together and creating spaces that feel thoughtful, welcoming, and genuinely supportive.
				</p>
				<p>
					BAAE stems from Nadine’s own desire for deeper friendships, inspiring conversations, and a sense of belonging. Her hope is that this community feels like a place where you can show up as you are, connect meaningfully, and build friendships that last.
				</p>
			</div>

			<div style="display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; background-color: var(--accent); color: var(--white); padding: 2em;">
				<h2 style="color: var(--white);">BAAE by the Numbers</h2>
				<h3 style="color: var(--white);">80</h3>
				<p>Women from all walks of life</p>
				<h3 style="color: var(--white);">65%</h3>
				<p>New to the California Bay Area</p>
				<h3 style="color: var(--white);">100%</h3>
				<p>Invested in friendship and personal growth</p>
			</div>

		</main>

		<Footer />

	<script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
	<script>
	if (window.netlifyIdentity) {
		window.netlifyIdentity.on("init", user => {
		if (!user) {
			window.netlifyIdentity.on("login", () => {
			document.location.href = "/admin/";
			});
		}
		});
	}
	</script>

	</body>
</html>
