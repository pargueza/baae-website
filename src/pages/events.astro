---
import BaseHead from '../components/BaseHead.astro';
import Button from '../components/Button.astro';
import CircleImage from '../components/CircleImage.astro';
import CTASection from '../components/CTASection.astro';
import DoubleColumn from '../components/DoubleColumn.astro';
import fallback from '../images/fallback.png';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import ScrollToTop from '../components/ScrollToTop.astro';
import ThreeColumn from '../components/ThreeColumn.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<div style="display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; background-color: var(--accent-green); color: var(--white); padding: 2em;">
				<h1 style="color: var(--white);">Attend Our Signature Events</h1>
				<h2 style="color: var(--white);">Feel-good gatherings to help you recharge, connect, and build real friendships. No awkward networking or pressure to perform.</h2>
				<Button href="/contact" text="Sign Up for the Newsletter" variant="main" />
			</div>

			<div style="display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: left;">
				<br>
				<h2 style="color: var(--accent);">Pancake Run</h2>
				<p>10:00 AM to 12:00 PM</p>
				<p>A relaxed weekend meetup with movement, conversation, and pancakes at the end. Come as you are. Walk, jog, or cheer from the sidelines.</p>
			
				<h2 style="color: var(--accent);">Dinner & Board Games Night</h2>
				<p>Monthly | 6:00 - 9:00 PM</p>
				<p>Low-key nights around the table with good food, laughter, and friendly competition. Bring a dish, a game, or just yourself.</p>
			
			</div>

			<div style="display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; background-color: var(--accent-dark); color: var(--white); padding: 2em;">
				<h2 style="color: var(--white);">Founders x Funders Pitch Night</h2>
				<p>When: Annual</p>
				<p>Discover seed and Series A startups in emerging industries, ask real questions, and explore opportunities.</p>
			</div>

			<div style="display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: left;">
				<iframe src="https://calendar.google.com/calendar/embed?height=600&wkst=1&ctz=America%2FLos_Angeles&showPrint=0&showTitle=0&mode=MONTH&showTz=0&showCalendars=0&src=NTY3MWM4YzdkNDRiZjEyMzExMmUyYTA5MDY4ZjIzNTU4ODEyZGQ5Y2Y3M2JlNTNjYzE5ZGU0OTEwZTMwZTA1MEBncm91cC5jYWxlbmRhci5nb29nbGUuY29t&color=%23f4511e" style="border-width:0" width="800" height="600" frameborder="0" scrolling="no"></iframe>
			</div>

		</main>

		<Footer />

	<script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
	<script>
	if (window.netlifyIdentity) {
		window.netlifyIdentity.on("init", user => {
		if (!user) {
			window.netlifyIdentity.on("login", () => {
			document.location.href = "/admin/";
			});
		}
		});
	}
	</script>

	</body>
</html>
